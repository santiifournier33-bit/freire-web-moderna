press%26cs%3Dtinysrgb%26w%3D400%26h%3D400%26fit%3Dcrop&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F1065084%2Fpexels-photo-1065084.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D400%26h%3D400%26fit%3Dcrop&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F1065084%2Fpexels-photo-1065084.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D400%26h%3D400%26fit%3Dcrop&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F1065084%2Fpexels-photo-1065084.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D400%26h%3D400%26fit%3Dcrop&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F1065084%2Fpexels-photo-1065084.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D400%26h%3D400%26fit%3Dcrop&amp;w=3840&amp;q=75\"/></div><div><div class=\"text-xs font-bold text-primary tracking-tight leading-snug\">Camila Herrera</div><div class=\"text-[11px] text-on-surface-variant leading-snug\">Pilar</div></div></div></div></div></div></div></div></section><section class=\"py-16 bg-surface-container-low\"><div class=\"container mx-auto px-6 max-w-4xl\"><div class=\"mb-10 text-center\"><span class=\"label-editorial mb-4 block\">Asesoramiento Directo</span><h2 class=\"text-4xl md:text-6xl font-bold text-primary tracking-[-0.03em]\">Preguntas <br/><span class=\"text-secondary italic font-normal\">Frecuentes</span></h2></div><div class=\"space-y-1 bg-surface-dim shadow-ambient\"><div class=\"bg-surface-container-lowest overflow-hidden transition-all duration-500\"><button class=\"w-full px-8 py-7 text-left flex items-center justify-between transition-colors duration-500 hover:bg-surface-container\" aria-expanded=\"false\"><h3 class=\"text-sm font-bold uppercase tracking-widest text-primary pr-8 leading-relaxed\">¿Cuáles son los primeros pasos para vender con nosotros?</h3><div class=\"flex-shrink-0 text-primary\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-5 h-5 stroke-[1.5]\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></div></button><div class=\"transition-all duration-700 ease-standard overflow-hidden max-h-0 opacity-0\"><div class=\"px-8 pb-10 pt-4\"><p class=\"text-base text-on-surface-variant leading-relaxed font-sans whitespace-pre-line border-t border-primary/5 pt-8\">1. Completas el formulario.\n2. Nos ponemos en contacto con vos.\n3. Realizamos la pretasación y evaluamos juntos tus posibilidades en la reunión.</p></div></div></div><div class=\"bg-surface-container-lowest overflow-hidden transition-all duration-500\"><button class=\"w-full px-8 py-7 text-left flex items-center justify-between transition-colors duration-500 hover:bg-surface-container\" aria-expanded=\"false\"><h3 class=\"text-sm font-bold uppercase tracking-widest text-primary pr-8 leading-relaxed\">¿Trabajan con exclusividad o puedo trabajar con otra inmobiliaria a la vez?</h3><div class=\"flex-shrink-0 text-primary\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-5 h-5 stroke-[1.5]\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></div></button><div class=\"transition-all duration-700 ease-standard overflow-hidden max-h-0 opacity-0\"><div class=\"px-8 pb-10 pt-4\"><p class=\"text-base text-on-surface-variant leading-relaxed font-sans whitespace-pre-line border-t border-primary/5 pt-8\">Trabajamos con exclusividad por 120 días, lo que nos permite enfocarnos al 100% en la venta de tu propiedad. Con esta modalidad, invertimos más en publicidad y marketing personalizado, asegurando que tus intereses sean nuestra prioridad y aprovechando nuestra experiencia y red de contactos para lograr la venta.</p></div></div></div><div class=\"bg-surface-container-lowest overflow-hidden transition-all duration-500\"><button class=\"w-full px-8 py-7 text-left flex items-center justify-between transition-colors duration-500 hover:bg-surface-container\" aria-expanded=\"false\"><h3 class=\"text-sm font-bold uppercase tracking-widest text-primary pr-8 leading-relaxed\">¿Cuáles son los costos adicionales a considerar al comprar o vender una propiedad?</h3><div class=\"flex-shrink-0 text-primary\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-5 h-5 stroke-[1.5]\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></div></button><div class=\"transition-all duration-700 ease-standard overflow-hidden max-h-0 opacity-0\"><div class=\"px-8 pb-10 pt-4\"><p class=\"text-base text-on-surface-variant leading-relaxed font-sans whitespace-pre-line border-t border-primary/5 pt-8\">Al comprar o vender una propiedad, es importante tener en cuenta los costos más allá del precio de compra. Estos incluyen los honorarios de la inmobiliaria, el impuesto de sellos, los gastos de escrituración, los honorarios de la escribanía, el estudio de títulos, y varios impuestos. Te proporcionaremos una proforma de gastos detallada para que puedas planificar y entender mejor estos costos.</p></div></div></div><div class=\"bg-surface-container-lowest overflow-hidden transition-all duration-500\"><button class=\"w-full px-8 py-7 text-left flex items-center justify-between transition-colors duration-500 hover:bg-surface-container\" aria-expanded=\"false\"><h3 class=\"text-sm font-bold uppercase tracking-widest text-primary pr-8 leading-relaxed\">¿Cuáles son sus honorarios y qué servicios están incluidos?</h3><div class=\"flex-shrink-0 text-primary\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-5 h-5 stroke-[1.5]\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></div></button><div class=\"transition-all duration-700 ease-standard overflow-hidden max-h-0 opacity-0\"><div class=\"px-8 pb-10 pt-4\"><p class=\"text-base text-on-surface-variant leading-relaxed font-sans whitespace-pre-line border-t border-primary/5 pt-8\">Nuestros honorarios se calculan como un porcentaje de la venta e incluyen una amplia variedad de servicios, desde el asesoramiento y la valoración de la propiedad, hasta la promoción de la propiedad y la gestión de las visitas, la negociación con los compradores y la coordinación de los aspectos legales y documentales de la venta.</p></div></div></div><div class=\"bg-surface-container-lowest overflow-hidden transition-all duration-500\"><button class=\"w-full px-8 py-7 text-left flex items-center justify-between transition-colors duration-500 hover:bg-surface-container\" aria-expanded=\"false\"><h3 class=\"text-sm font-bold uppercase tracking-widest text-primary pr-8 leading-relaxed\">¿Cuánto tiempo suelen estar en el mercado las propiedades antes de venderse?</h3><div class=\"flex-shrink-0 text-primary\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-5 h-5 stroke-[1.5]\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></div></button><div class=\"transition-all duration-700 ease-standard overflow-hidden max-h-0 opacity-0\"><div class=\"px-8 pb-10 pt-4\"><p class=\"text-base text-on-surface-variant leading-relaxed font-sans whitespace-pre-line border-t border-primary/5 pt-8\">Las propiedades que están correctamente valoradas y bien presentadas suelen recibir reservas dentro de los primeros 4 meses. Nuestro objetivo es trabajar contigo para asegurarnos de que tu propiedad se venda en un tiempo óptimo y al mejor precio posible.</p></div></div></div><div class=\"bg-surface-container-lowest overflow-hidden transition-all duration-500\"><button class=\"w-full px-8 py-7 text-left flex items-center justify-between transition-colors duration-500 hover:bg-surface-container\" aria-expanded=\"false\"><h3 class=\"text-sm font-bold uppercase tracking-widest text-primary pr-8 leading-relaxed\">¿Cómo me aseguro de vender y comprar sin quedarme en la calle?</h3><div class=\"flex-shrink-0 text-primary\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-5 h-5 stroke-[1.5]\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></div></button><div class=\"transition-all duration-700 ease-standard overflow-hidden max-h-0 opacity-0\"><div class=\"px-8 pb-10 pt-4\"><p class=\"text-base text-on-surface-variant leading-relaxed font-sans whitespace-pre-line border-t border-primary/5 pt-8\">Podemos condicionar tu venta a tu reubicación y solo vendes en simultáneo con tu compra sin riesgo y sin penalidades en caso que no se concrete ninguna operación.</p></div></div></div><div class=\"bg-surface-container-lowest overflow-hidden transition-all duration-500\"><button class=\"w-full px-8 py-7 text-left flex items-center justify-between transition-colors duration-500 hover:bg-surface-container\" aria-expanded=\"false\"><h3 class=\"text-sm font-bold uppercase tracking-widest text-primary pr-8 leading-relaxed\">¿Qué documentación necesito para vender?</h3><div class=\"flex-shrink-0 text-primary\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-5 h-5 stroke-[1.5]\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></div></button><div class=\"transition-all duration-700 ease-standard overflow-hidden max-h-0 opacity-0\"><div class=\"px-8 pb-10 pt-4\"><p class=\"text-base text-on-surface-variant leading-relaxed font-sans whitespace-pre-line border-t border-primary/5 pt-8\">Título del inmueble, DNI del titular, impuestos municipales y provinciales, planos (si los hubiere) y autorización de venta firmada por todos los propietarios.</p></div></div></div></div></div></section><a href=\"https://wa.me/5491151454915?text=Hola.%20Vi%20su%20pagina%20y%20me%20gustaria%20saber%20m%C3%A1s%20informaci%C3%B3n%20sobre%20sus%20servicios%20inmobiliarios\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"fixed bottom-6 right-6 z-[100] w-14 h-14 bg-[#25D366] hover:bg-[#1DA851] rounded-full shadow-lg hover:shadow-2xl flex items-center justify-center transition-all duration-300 hover:scale-110 group cursor-pointer\" title=\"Contactar por WhatsApp\" aria-label=\"Contactar por WhatsApp\"><div class=\"relative w-8 h-8\"><img alt=\"WhatsApp Logo\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-contain\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fwhatsapp-blanco.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fwhatsapp-blanco.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fwhatsapp-blanco.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fwhatsapp-blanco.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fwhatsapp-blanco.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fwhatsapp-blanco.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fwhatsapp-blanco.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fwhatsapp-blanco.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fwhatsapp-blanco.png&amp;w=3840&amp